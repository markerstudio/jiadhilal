# Firebase web config is baked into src/lib/firebaseStore.ts (public values;
# access is controlled by Firestore security rules). These env vars OVERRIDE
# the baked-in defaults — useful for pointing at a different project.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_APP_ID=

# Set to "true" to force demo mode (localStorage, seeded data, no backend):
VITE_FIREBASE_DISABLED=
